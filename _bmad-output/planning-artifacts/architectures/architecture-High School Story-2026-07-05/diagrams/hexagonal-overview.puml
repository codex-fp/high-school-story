@startuml
title High School Story - Hexagonal Architecture Framework

skinparam shadowing false
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam componentStyle rectangle
skinparam packageStyle rectangle

skinparam rectangle {
  BorderColor #2f2a26
  BackgroundColor #fff8ea
  RoundCorner 16
}

skinparam package {
  BorderColor #2f2a26
  BackgroundColor #fffdf6
  RoundCorner 18
}

skinparam component {
  BorderColor #2f2a26
  BackgroundColor #f8efe0
  RoundCorner 12
}

skinparam interface {
  BorderColor #2f2a26
  BackgroundColor #eef5ff
}

skinparam note {
  BorderColor #66594c
  BackgroundColor #fff8df
}

left to right direction

rectangle "Primary / Driving Infrastructure" as PrimaryInfra #dfeeda {
  component "Infrastructure Component\nGodot input / CLI / debug UI" as DrivingInfraComponent <<Infrastructure Component>>
}

rectangle "Inbound Adapter" as InboundAdapterArea #eef5ff {
  component "InputAdapter\ntranslates external intent to Application API" as InboundAdapter <<Inbound Adapter>>
}

hexagon "Core" as Core #fff8ea {
  rectangle "Inbound Port\nApplication API" as InboundPortArea #ffffff {
    interface "Application Command / Query API" as InboundPort <<Inbound Port>>
  }

  rectangle "Application" as Application #fff3d8 {
    component "Command Handler" as CommandHandler <<Command Handler>>
    component "Query Handler" as QueryHandler <<Query Handler>>
    component "Application Service" as ApplicationService <<Application Service>>
    component "Read Model / Projection" as Projection <<Read Model>> <<Reactive Projection>>
    interface "IProjectionReader\nread-only R3 streams" as ProjectionReader <<Projection Reader API>>

    rectangle "Domain" as Domain #ffffff {
      component "Domain Model\nAggregate / Entity / Value Object" as DomainModel <<Domain Model>>
      component "Domain Service / Policy" as DomainService <<Domain Service>>
      component "Domain Event / Result" as DomainEvent <<Domain Event>>
    }
  }

  rectangle "Outbound Port" as OutboundPortArea #ffffff {
    interface "ISaveStore / IClock /\nIAudioOutput / IContentRepository" as OutboundPort <<Outbound Port>>
  }
}

rectangle "Outbound Adapter" as OutboundAdapterArea #eef5ff {
  component "OutputAdapter\nimplements outbound port" as OutboundAdapter <<Outbound Adapter>>
}

rectangle "Secondary / Driven Infrastructure" as SecondaryInfra #f8c995 {
  component "Infrastructure Component\nfile system / audio / clock / content source" as DrivenInfraComponent <<Infrastructure Component>>
}

rectangle "Presentation Infrastructure" as PresentationInfra #f8efe0 {
  component "Presenter\nbinds Application projection to Godot view" as Presenter <<Presenter>>
  component "View\nGodot scene / control / node tree" as View <<View>>
}

DrivingInfraComponent --> InboundAdapter
InboundAdapter --> InboundPort
InboundPort --> CommandHandler
InboundPort --> QueryHandler

CommandHandler --> ApplicationService
QueryHandler --> ApplicationService
ApplicationService --> DomainModel : aggregate methods
ApplicationService --> DomainService : policies / cross-aggregate rules
DomainModel --> DomainService
DomainModel --> DomainEvent : produces
DomainService --> DomainEvent : produces
DomainEvent --> CommandHandler : returned to Application

CommandHandler --> OutboundPort
ApplicationService --> OutboundPort
OutboundPort <|.. OutboundAdapter
OutboundAdapter --> DrivenInfraComponent

CommandHandler --> Projection
QueryHandler --> Projection
Projection --> ProjectionReader : exposes
Presenter --> ProjectionReader : subscribes
Presenter --> View

note bottom of Core
  Dependencies cross into Core through ports.
  Core contains Application; Application contains Domain.
end note

note bottom of Domain
  Domain is plain C# canonical gameplay truth.
  No Godot, no R3, no JSON, no Ports, no logging.
end note

note bottom of PresentationInfra
  Presentation is infrastructure.
  Presenters do not query Domain directly and do not mutate GameState.
end note

@enduml
