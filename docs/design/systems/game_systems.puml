@startuml High School Story — Game Systems

skinparam componentStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam component {
    BackgroundColor #EBF8FF
    BorderColor #2B6CB0
    FontSize 11
}
skinparam package {
    BackgroundColor #F7FAFC
    BorderColor #4A5568
    FontStyle bold
}
skinparam interface {
    BackgroundColor #FFF5F5
    BorderColor #C53030
}
skinparam note {
    BackgroundColor #FFFBEB
    BorderColor #D69E2E
    FontSize 10
}

title High School Story — Game Systems Overview

package "⏱️ Core Loop" {
    [Time & Calendar] as time
    [Daily Loop Scheduler] as daily
    [Story / Beat System] as story
}

package "📊 Player State" {
    [Stat System] as stats
    note bottom of stats : Energy, Stress, Mood\n0–100, daily decay
    [Inventory & Items] as inventory
    [Economy / Currency] as economy
    [Progression / Academic] as progression
}

package "🧑‍🤝‍🧑 Social Systems" {
    [Relationship System] as relationships
    [NPC Behavior & Scheduling] as npc
    [Dialogue System] as dialogue
}

package "🏫 Gameplay Mechanics" {
    [Classroom Mechanic] as classroom
    note bottom of classroom : Turn-based action system\nduring class periods
    [Club System] as clubs
    [Part-Time Jobs] as jobs
    [Event & Cutscene System] as events
}

package "🗺️ World" {
    [Location & World System] as world
    [Character & Movement] as character
}

package "📱 UI & Devices" {
    [Smartphone] as phone
    note bottom of phone : Messaging, Social Feed,\nMap, Shop, School App
    [UI Framework] as ui
}

package "💾 Infrastructure" {
    [Save / Load] as save
    [Audio] as audio
}

' Core dependencies
time        --> daily       : drives
daily       --> story       : triggers beats
daily       --> classroom   : schedules class periods
daily       --> clubs       : schedules club hours

' Player state interactions
stats       <-- classroom   : gain/loss per action
stats       <-- inventory   : item modifiers
stats       <-- relationships : mood bonus from NPCs
stats       --> progression : knowledge feeds exam scores
economy     <-- jobs        : earns currency
economy     --> inventory   : buy items

' Social
relationships <-- dialogue  : choices affect score
relationships <-- events    : cutscenes unlock/require
npc         --> dialogue    : NPC initiates scenes
npc         <-- time        : NPC daily schedules

' World
world       --> character   : player navigates locations
world       <-- time        : travel costs time
world       <-- story       : beats unlock locations

' UI / Devices
phone       --> dialogue    : SMS story events
phone       --> world       : map / fast travel
phone       --> economy     : online shop
phone       --> stats       : social media (passive mood)
ui          --> dialogue    : renders dialogue box
ui          --> stats       : HUD overlays
ui          --> phone       : phone UI overlay

' Infrastructure
save        --> stats       : persists state
save        --> relationships
save        --> progression
audio       --> events      : BGM for cutscenes
audio       --> classroom   : ambient SFX

@enduml
