@startuml High School Story — Classroom Mechanic

skinparam backgroundColor #FAFAFA
skinparam state {
    BackgroundColor #EBF8FF
    BorderColor #2B6CB0
    FontSize 11
}
skinparam note {
    BackgroundColor #FFFBEB
    BorderColor #D69E2E
    FontSize 10
}

title Classroom Mechanic — State Machine

[*] --> ClassInProgress : Period begins (45 min)

state ClassInProgress {
    [*] --> PlayerTurn

    state PlayerTurn {
        state "Choose Action" as choose
        [*] --> choose
    }

    ' ─── Safe Actions ─────────────────────────────────────────────────
    state "📖 Study / Focus" as study
    study : Knowledge + (subject)
    study : No catch risk

    state "🙋 Participate Actively" as participate
    participate : Knowledge ++ (high reward)
    participate : Teacher Rel. +
    participate : Stress + (pressure)

    state "😴 Daydream / Rest" as rest
    rest : Energy +, Mood +
    rest : Knowledge = 0
    rest : Low catch risk

    ' ─── Risky Actions ─────────────────────────────────────────────────
    state "📝 Pass Notes / Socialize" as socialize
    socialize : Relationship + (nearby NPC)
    socialize : **Catch risk: medium**

    state "📱 Text on Phone" as text
    text : Relationship + (recipient)
    text : **Catch risk: medium-high**

    state "📵 Surf Social Media" as social
    social : Mood +
    social : **Catch risk: high**

    state "📕 Read Off-Topic Book" as read
    read : Mood +, Knowledge (unrelated)
    read : **Catch risk: low**

    state "🍫 Use Item (Consumable)" as item
    item : Stat effect of item (Energy, Mood, etc.)
    item : **Catch risk: medium**

    ' Transitions from choose
    choose --> study      : Study
    choose --> participate : Participate
    choose --> rest       : Daydream
    choose --> socialize  : Socialize
    choose --> text       : Use phone (text)
    choose --> social     : Use phone (social media)
    choose --> read       : Read book
    choose --> item       : Use item

    ' ─── Catch Resolution ─────────────────────────────────────────────
    state CatchCheck <<choice>>

    socialize --> CatchCheck
    text       --> CatchCheck
    social     --> CatchCheck
    read       --> CatchCheck
    item       --> CatchCheck

    state "😮 Caught!" as caught
    caught : Teacher notices player
    caught : Mood –, Stress +

    state "😌 Not Caught" as safe
    safe : Action completes normally

    CatchCheck --> caught : Teacher attention roll: fail
    CatchCheck --> safe   : Teacher attention roll: pass

    state "📎 Consequence" as consequence
    consequence : Stacking severity:\n1st time → warning (Mood –)\n2nd time → public scolding (Stress +, Teach Rel. –)\n3rd time → detention after school

    caught --> consequence

    ' Loop back to next turn
    study       --> PlayerTurn : Next turn
    participate --> PlayerTurn : Next turn
    rest        --> PlayerTurn : Next turn
    safe        --> PlayerTurn : Next turn
    consequence --> PlayerTurn : Next turn
}

ClassInProgress --> PeriodEnd : 45 min elapsed

state PeriodEnd {
    state "📊 Period Summary" as summary
    summary : Knowledge gain applied\nRelationship deltas applied\nEnergy / Mood / Stress updated
}

PeriodEnd --> [*]

note as N1
    **Catch risk modifiers:**
    Teacher personality (strict vs lenient) affects base catch rate.
    Teacher Relationship score can lower catch rate slightly.
    Sitting in the back row: –5% catch rate.
    Prior detentions: teacher is on alert, +10% catch rate.
end note

note as N2
    **Detention:**
    Costs 1 after-school time slot.
    Cannot attend Club Hour or visit town.
    Relationship with that teacher drops permanently (–5).
end note

@enduml
